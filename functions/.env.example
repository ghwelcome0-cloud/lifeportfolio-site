# =================================================================
# PayPal Configuration (DO NOT commit actual values)
# =================================================================
# Use this command to register secrets (NEVER write real values here):
#
#   firebase functions:config:set \
#     paypal.env="sandbox" \
#     paypal.client_id_sandbox="YOUR_SANDBOX_CLIENT_ID" \
#     paypal.secret_sandbox="YOUR_SANDBOX_SECRET" \
#     paypal.price_usd="8.99"
#
# After live verification:
#   firebase functions:config:set \
#     paypal.env="live" \
#     paypal.client_id_live="YOUR_LIVE_CLIENT_ID" \
#     paypal.secret_live="YOUR_LIVE_SECRET"
#
# Verify configuration (no secrets shown in output):
#   firebase functions:config:get
#
# Deploy functions only:
#   firebase deploy --only functions
# =================================================================

PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID_SANDBOX=
PAYPAL_SECRET_SANDBOX=
PAYPAL_CLIENT_ID_LIVE=
PAYPAL_SECRET_LIVE=
PAYPAL_PRICE_USD=8.99
