# =================================================================
# Firebase Functions v2 - Configuration Guide
# =================================================================
# 이 프로젝트는 두 가지 방식으로 설정값을 관리합니다:
#
#   (1) Secret Manager (민감 정보)  → firebase functions:secrets:set
#   (2) .env 파일 (일반 환경변수)   → 이 파일을 functions/.env 로 복사
#
# =================================================================
# (1) 시크릿 등록 — Google Secret Manager (안전, 영구 저장)
# =================================================================
# 다음 명령어를 PowerShell/Terminal 에서 1회 실행 (대화형 입력):
#
#   [PayPal — 결제 검증]
#   firebase functions:secrets:set PAYPAL_CLIENT_ID_SANDBOX
#   firebase functions:secrets:set PAYPAL_SECRET_SANDBOX
#
#   [Resend — 21일 점검 D22 이메일 발송 (Sprint Week 2)]
#   firebase functions:secrets:set RESEND_API_KEY
#
# Live 인증 완료 후 추가 등록:
#   firebase functions:secrets:set PAYPAL_CLIENT_ID_LIVE
#   firebase functions:secrets:set PAYPAL_SECRET_LIVE
#
# 등록된 시크릿 목록 확인:
#   firebase functions:secrets:access PAYPAL_SECRET_SANDBOX
#   firebase functions:secrets:access RESEND_API_KEY
#
# 시크릿 갱신/회전:
#   firebase functions:secrets:set PAYPAL_SECRET_SANDBOX  (다시 실행하면 새 버전 생성)
#
# =================================================================
# (2) 일반 환경변수 — functions/.env 파일에 저장
# =================================================================
# 이 파일을 'functions/.env' 로 복사한 뒤 값을 입력하세요.
# .env 파일은 .gitignore 처리되어 절대 커밋되지 않습니다.
# 시크릿(API 키, 비밀번호)은 절대 .env 에 넣지 말 것!

# ---- PayPal ----
PAYPAL_ENV=sandbox
PAYPAL_PRICE_USD=8.99

# Live 전환 시:
# PAYPAL_ENV=live

# ---- Resend (21일 점검 D22 이메일) ----
# 발신 이메일은 lifeportfolio.co.kr 도메인의 메일 주소를 사용해야 합니다.
# (Resend 대시보드에서 도메인 등록 + DKIM/SPF/DMARC DNS 레코드 추가 필수)
RESEND_FROM_EMAIL_KO=Life Portfolio <faise@lifeportfolio.co.kr>
RESEND_FROM_EMAIL_EN=Life Portfolio <faise@lifeportfolio.co.kr>
RESEND_REPLY_TO=faise@lifeportfolio.co.kr

# 자가 점검 폼 URL (Sprint Week 3 — 12문항 자가 점검 폼)
# ⚠️ 중요: 반드시 -form 접미사가 붙은 페이지여야 함.
#   - checkin-21.html      → 사전신청(결제) 페이지 (X, 사용 금지)
#   - checkin-21-form.html → 12문항 자가 점검 폼   (O, 정답)
# (만약 실수로 -form 없는 URL 입력해도 functions/index.js 의 normalizeD22FormBaseUrl
#  자가치유 로직이 자동으로 -form 버전으로 교정함 — but 명시적으로 -form 권장)
D22_FORM_BASE_URL_KO=https://lifeportfolio.co.kr/checkin-21-form.html
D22_FORM_BASE_URL_EN=https://lifeportfolio.co.kr/checkin-21-form-en.html

# Resend 발송 지연 시각 차단 (안전망):
# purchase_date 가 너무 오래된 데이터(예: 60일 이상)는 자동 발송 제외 — D22 미스 방지 + 폭발 발송 차단
D22_LOOKBACK_DAYS_MAX=60

# ---- PR #91: 사전 진단 → 1:1 코칭 예약 운영자 알림 ----
# 채팅 종료 시 [📞 1:1 코칭 예약하기] 버튼을 누르면, requestEscalation Callable 이
# 운영자에게 메일을 보냅니다 (사용자의 12문항 + 4개 자유 메모 + 예약 메모를 모두 포함).
# 이 변수가 미설정 / 빈 값 / 잘못된 이메일이면 자동으로 RESEND_REPLY_TO 와 같은 값
# (faise@lifeportfolio.co.kr) 으로 폴백됩니다.
OPERATOR_NOTIFICATION_EMAIL=faise@lifeportfolio.co.kr

# ---- testD22EmailSend (라이브 미리보기 발송) ----
# 콤마 구분 도메인 화이트리스트. 빈 값이면 모든 발송 차단(안전 기본값).
# 운영진 + 운영 도메인만 허용 — 무단 외부 발송 차단.
TEST_D22_ALLOWED_DOMAINS=lifeportfolio.co.kr,gmail.com

# =================================================================
# 배포
# =================================================================
#   cd functions && npm install && cd ..
#   firebase deploy --only functions,database --project lifeporfolio
#
# =================================================================
#
# Resend 사전 준비 체크리스트:
#   1. https://resend.com 가입
#   2. Domains 에서 lifeportfolio.co.kr 추가
#   3. 발급된 DKIM / SPF / DMARC TXT 레코드를 도메인 DNS에 추가
#   4. Region: ap-northeast-1 (Tokyo) 권장 — 한국 사용자 < 50ms
#   5. API Keys 메뉴에서 API Key 발급 → firebase functions:secrets:set RESEND_API_KEY 로 등록
#
# =================================================================
