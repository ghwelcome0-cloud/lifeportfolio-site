rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// LifePortfolio Firestore Rules
// ─────────────────────────────────────────────────────────────────────────────
// ⚠️ 중요: 이 파일은 Firestore Rules 입니다 (database.rules.json 은 RTDB 전용).
//
// 운영 사용 컬렉션 (2026-05 기준):
//   - checkin21_preorders : 21일 점검 동행 사전 신청 (익명 쓰기 허용 + 서버 갱신)
//   - (그 외 결제/리포트/사용자 데이터는 현재 RTDB 사용 중)
//
// 배포 방법:
//   1) firebase.json 에 firestore 섹션이 있는지 확인 (있어야 deploy 됨)
//   2) firebase deploy --only firestore:rules
//   ※ 또는 Firebase Console > Firestore > Rules 에서 직접 편집/배포 가능.
//   ※ 운영본(Console)과 로컬 파일이 항상 일치하도록 관리할 것!
//
// ─────────────────────────────────────────────────────────────────────────────
// 핵심 원칙:
//   1) 인증되지 않은 모든 접근 차단 (기본 deny)
//   2) 본인 데이터(uid 일치)만 읽기/쓰기 허용
//   3) 결제/주문 등 민감 데이터는 Cloud Functions(서버)에서만 쓰기 허용
//   4) 사전 신청은 익명 쓰기 허용 + 화이트리스트 검증 + 읽기는 서버만
// ─────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // 기본: 모두 차단 (명시되지 않은 모든 컬렉션은 deny)
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // 사용자 프로필 (Firestore 사용 시) — 현재는 RTDB 사용 중이라 비활성
    // ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validUserData(request.resource.data);
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && validUserData(request.resource.data)
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // 결제/주문 — 서버 전용 쓰기
    // ─────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /payments/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validPaymentData(request.resource.data);
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ checkin21_preorders — 21일 점검 동행 사전 신청 (운영 중)
    // ─────────────────────────────────────────────────────────────
    //   PR #94 (2026-05-16) — 게이트 강화:
    //     이전: 익명 client create 허용 (validPreorderData 형식 검증만)
    //     변경: 모든 create 차단 → Callable `submitCheckin21Preorder` 만 통과
    //
    //   서버 Callable 이 검증하는 4가지:
    //     1) request.auth.uid 존재 (로그인)
    //     2) RTDB payments/{uid}/paid === true (₩9,900 결제)
    //     3) RTDB reports/{uid} 노드 존재 (76문항 진단 완료)
    //     4) Firestore 동일 uid 사전 신청 없음 (중복 차단)
    //
    //   문서 스키마에 PR #94 부터 `uid` 필드 추가 (게이트 추적용).
    //   payment_status 도 'not_invoiced' → 'paid_pre_offer' 로 변경.
    //
    //   read / update / delete: 서버(Admin SDK) 전용 — 별도 허용 불필요.
    // ─────────────────────────────────────────────────────────────
    match /checkin21_preorders/{docId} {
      // PR #94 — 클라이언트 익명 create 차단. Callable 서버만 통과.
      allow create: if false;

      // 읽기/수정/삭제는 서버(Admin SDK)에서만
      // ※ Admin SDK 는 보안 규칙을 우회하므로 별도 허용 불필요
      allow read, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // 🧪 _test_email_log — D22 시뮬레이션 발송 로그 (서버 전용)
    // ─────────────────────────────────────────────────────────────
    //   - testD22EmailSend Callable Function 이 rate limit 추적용으로 기록
    //   - 클라이언트는 절대 접근 불가 (Admin SDK 만 사용)
    //   - 운영 컬렉션(checkin21_preorders) 과 완전히 분리
    // ─────────────────────────────────────────────────────────────
    match /_test_email_log/{docId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ checkin21_responses — 21일 자가 점검 12문항 응답 (Sprint Week 3)
    // ─────────────────────────────────────────────────────────────
    //   - submitCheckinResponse Callable Function 이 Admin SDK 로 add()
    //   - 직접 client SDK 쓰기는 절대 차단 (HMAC 서명 검증 우회 방지)
    //   - 읽기는 서버 전용 (Week 4 대시보드에서 Admin SDK 사용)
    //   - 추후 본인 응답 조회가 필요할 경우 토큰 기반 Callable Function 추가
    // ─────────────────────────────────────────────────────────────
    match /checkin21_responses/{docId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ checkin21_chat_logs — 채팅 30분 대화 turn 로그 (PR #90)
    // ─────────────────────────────────────────────────────────────
    //   - submitChatTurn Callable 이 Admin SDK 로 turn 단위 append
    //   - 클라이언트 직접 쓰기 차단 (HMAC + 노드 화이트리스트 우회 방지)
    //   - 읽기는 운영진 대시보드(Week 4) 전용
    // ─────────────────────────────────────────────────────────────
    match /checkin21_chat_logs/{docId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ checkin21_chat_escalations — 운영진 연결 요청 큐 (PR #90)
    // ─────────────────────────────────────────────────────────────
    //   - requestEscalation Callable 이 Admin SDK 로 add()
    //   - 운영자가 status: pending → scheduled → contacted → resolved 로 전이
    //   - 모든 쓰기/읽기 서버 전용
    // ─────────────────────────────────────────────────────────────
    match /checkin21_chat_escalations/{docId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ✅ coach_availability — 코치 가능 시간 슬롯 (PR #91 r2)
    // ─────────────────────────────────────────────────────────────
    //   - 운영자(코치)가 Firebase Console 또는 Admin SDK 로 슬롯 추가
    //   - getCoachAvailability Callable 이 Admin SDK 로 active=true 슬롯 조회
    //   - requestEscalation Callable 이 Admin SDK 로 transaction 예약 처리
    //     (booked_count 증가)
    //   - 클라이언트 직접 접근 불가 (모든 흐름은 Callable 경유)
    //   - 향후 운영 대시보드 (PR #92+) 에서 admin UI 로 관리
    //
    //   문서 필드:
    //     - slot_at (Timestamp)        : 예약 가능 시각
    //     - duration_min (number)      : 통화 길이 (기본 30)
    //     - capacity (number)          : 동시 예약 가능 인원 (기본 1)
    //     - booked_count (number)      : 현재까지 예약된 인원 (기본 0)
    //     - active (bool)              : 활성 여부 (기본 true)
    //     - notes (string, optional)   : 운영자 메모
    //     - created_at (Timestamp, optional)
    //     - last_booked_at (Timestamp, optional)
    // ─────────────────────────────────────────────────────────────
    match /coach_availability/{slotId} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // 검증 함수
    // ─────────────────────────────────────────────────────────────

    function validUserData(d) {
      return d.keys().hasOnly(['email', 'displayName', 'createdAt', 'lastLogin'])
        && d.email is string && d.email.size() <= 254
        && d.displayName is string && d.displayName.size() <= 80
        && d.createdAt is string && d.createdAt.size() <= 40
        && d.lastLogin is string && d.lastLogin.size() <= 40;
    }

    function validPaymentData(d) {
      return d.keys().hasOnly(['paid', 'createdAt', 'source'])
        && d.paid is bool && d.paid == true
        && d.createdAt is string && d.createdAt.size() <= 40
        && (!('source' in d) || (d.source is string && d.source.size() <= 40));
    }

    // ─────────────────────────────────────────────────────────────
    // PR #94 (2026-05-16) — checkin21_preorders 검증 로직 이전
    // ─────────────────────────────────────────────────────────────
    //   이전: 익명 client create 허용 + validPreorderData(...) 형식 검증
    //   변경: 모든 client create 차단 (allow create: if false) 후
    //         Callable `submitCheckin21Preorder` 에서 4-step 게이트:
    //           1) request.auth.uid (로그인)
    //           2) RTDB payments/{uid}/paid === true (₩9,900 결제)
    //           3) RTDB reports/{uid} 노드 존재 (76문항 진단 완료)
    //           4) Firestore 동일 uid 사전 신청 없음 (중복 차단)
    //         + 필드 길이/형식 검증은 Callable 내부에서 수행
    //
    //   이전의 validPreorderData(...) Rules 함수는 사용처가 사라져 삭제됨.
    //   필요 시 Git 히스토리(commit 8aeaadd 이전)에서 복원 가능.
    // ─────────────────────────────────────────────────────────────
  }
}
