rules_version = '2';

// 현재 코드는 Realtime Database를 사용 중입니다 (database.rules.json 참고).
// Firestore도 함께 사용한다면 아래 규칙을 Firebase Console > Firestore > 규칙 에 적용하세요.
// 핵심 원칙:
//   1) 인증되지 않은 모든 접근 차단
//   2) 본인 데이터(uid 일치)만 읽기/쓰기 허용
//   3) 결제/주문 등 민감 데이터는 Cloud Functions(서버)에서만 쓰기 허용
service cloud.firestore {
  match /databases/{database}/documents {

    // 기본: 모두 차단
    match /{document=**} {
      allow read, write: if false;
    }

    // 사용자 프로필: 본인만 읽기/쓰기, 필드 화이트리스트 검증
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validUserData(request.resource.data);
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && validUserData(request.resource.data)
                    // createdAt 은 변경 불가
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false; // 삭제는 콘솔/서버에서만
    }

    // 결제/주문: 사용자는 읽기만, 쓰기는 서버(Cloud Functions)만
    match /orders/{orderId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false; // Admin SDK 또는 서버에서만 작성
    }

    // 검사 응답/리포트: 본인 것만 읽기, 쓰기는 서버에서만
    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    function validUserData(d) {
      return d.keys().hasOnly(['email', 'displayName', 'createdAt', 'lastLogin'])
        && d.email is string && d.email.size() <= 254
        && d.displayName is string && d.displayName.size() <= 80
        && d.createdAt is string && d.createdAt.size() <= 40
        && d.lastLogin is string && d.lastLogin.size() <= 40;
    }
  }
}
