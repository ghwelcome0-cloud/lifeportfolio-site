{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "email": {
          ".validate": "newData.isString() && newData.val().length <= 254 && (newData.val() === '' || newData.val().matches(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/))"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "createdAt": {
          ".validate": "newData.isString() && newData.val().length <= 40 && (!data.exists() || data.val() === newData.val())"
        },
        "lastLogin": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },

        "reports": {
          "$sid": {
            "sid": {
              ".validate": "newData.isString() && newData.val().length <= 80 && (!data.exists() || data.val() === newData.val())"
            },
            "generatedAt": {
              ".validate": "(newData.isNumber() || (newData.isString() && newData.val().length <= 40)) && (!data.exists() || data.val() === newData.val())"
            },
            "toneKey": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
            },
            "name": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
            },
            "submittedAt": {
              ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)"
            },
            "lang": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 8)"
            },
            "$other": { ".validate": false }
          }
        },

        "programs": {
          "$sid": {
            "sid": {
              ".validate": "newData.isString() && newData.val().length <= 80 && (!data.exists() || data.val() === newData.val())"
            },
            "sourceSid": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80 && (!data.exists() || data.val() === newData.val()))"
            },
            "generatedAt": {
              ".validate": "(newData.isNumber() || (newData.isString() && newData.val().length <= 40)) && (!data.exists() || data.val() === newData.val())"
            },
            "toneKey": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
            },
            "name": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
            },
            "lang": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 8)"
            },
            "$other": { ".validate": false }
          }
        }
      }
    },

    "payments": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && (!data.exists() || data.child('paid').val() !== true)",

        ".validate": "newData.hasChildren(['paid', 'createdAt']) || newData.hasChild('_pending')",

        "paid": {
          ".validate": "newData.isBoolean() && newData.val() === true"
        },
        "createdAt": {
          ".validate": "newData.isString() && newData.val().length <= 40 && (!data.exists() || data.val() === newData.val())"
        },
        "source": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "provider": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "env": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "orderID": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "captureID": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "amount": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "currency": {
          ".validate": "newData.isString() && newData.val().length <= 10"
        },
        "_pending": {
          ".validate": "newData.val() === null || newData.hasChildren(['provider'])",
          "provider":  { ".validate": "newData.isString() && newData.val().length <= 40" },
          "env":       { ".validate": "newData.isString() && newData.val().length <= 20" },
          "orderID":   { ".validate": "newData.isString() && newData.val().length <= 80" },
          "amount":    { ".validate": "newData.isString() && newData.val().length <= 20" },
          "currency":  { ".validate": "newData.isString() && newData.val().length <= 10" },
          "createdAt": { ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)" },
          "$other":    { ".validate": false }
        },

        "$other": {
          ".validate": false
        }
      }
    },

    "responses": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "_active": {
          ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
        },

        "$sid": {
          ".validate": "newData.hasChildren(['status'])",

          "status": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "submittedAt": {
            ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)"
          },
          "startedAt": {
            ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)"
          },
          "updatedAt": {
            ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)"
          },
          "name": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
          },
          "email": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 254)"
          },
          "recvMethod": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 254)"
          },
          "userAgent": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 512)"
          },
          "lang": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 8)"
          },
          "meta": {
            "step": {
              ".validate": "newData.isNumber()"
            },
            "answered": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
            }
          },
          "answers": {
            "$qid": {
              ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren() || newData.val() === null"
            }
          },
          "$other": { ".validate": false }
        }
      }
    },

    "reports": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "$sid": {
          ".validate": "!data.exists() || !data.child('editCount').exists() || data.child('editCount').val() < 999",

          "sid": {
            ".validate": "newData.isString() && newData.val().length <= 80 && (!data.exists() || data.val() === newData.val())"
          },
          "generatedAt": {
            ".validate": "(newData.isNumber() || newData.isString()) && (!data.exists() || data.val() === newData.val())"
          },
          "engineVersion": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "rulesVersion": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "toneKey": {
            ".validate": "newData.isString() && newData.val().length <= 80"
          },
          "pdfFilename": {
            ".validate": "newData.isString() && newData.val().length <= 200"
          },
          "manualReportStatus": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "manualOverrideHtml": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 200000)"
          },
          "editCount": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999 && (!data.exists() || newData.val() >= data.val())"
          },
          "lastEditedAt": {
            ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)"
          },
          "lang": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 8)"
          },
          "_v4ApplyError": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 500)"
          },
          "_v4Applied": {
            ".validate": "newData.val() === null || newData.isBoolean()"
          },
          "report": {}
        }
      }
    },

    "programs": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "$sid": {
          ".validate": "!data.exists() || !data.child('editCount').exists() || data.child('editCount').val() < 999",

          "sid": {
            ".validate": "newData.isString() && newData.val().length <= 80 && (!data.exists() || data.val() === newData.val())"
          },
          "sourceSid": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80 && (!data.exists() || data.val() === newData.val()))"
          },
          "generatedAt": {
            ".validate": "(newData.isNumber() || newData.isString()) && (!data.exists() || data.val() === newData.val())"
          },
          "engineVersion": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "rulesVersion": {
            ".validate": "newData.isString() && newData.val().length <= 20"
          },
          "toneKey": {
            ".validate": "newData.isString() && newData.val().length <= 80"
          },
          "name": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 80)"
          },
          "manualProgramStatus": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 20)"
          },
          "manualOverrideHtml": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 200000)"
          },
          "editCount": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999 && (!data.exists() || newData.val() >= data.val())"
          },
          "lastEditedAt": {
            ".validate": "newData.isNumber() || (newData.isString() && newData.val().length <= 40)"
          },
          "lang": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length <= 8)"
          },
          "program": {}
        }
      }
    },

    "config": {
      ".read": "auth != null",
      ".write": false
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
